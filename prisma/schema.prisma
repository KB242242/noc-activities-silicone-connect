generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                   @id @default(cuid())
  email               String                   @unique(map: "uk_users_email")
  name                String
  firstName           String?                  @map("first_name")
  lastName            String?                  @map("last_name")
  username            String?                  @unique(map: "uk_users_username")
  passwordHash        String?                  @map("password_hash") @db.VarChar(500)
  role                users_role?              @default(USER)
  shiftId             String?                  @map("shift_id")
  responsibility      users_responsibility?
  shiftPeriodStart    DateTime?                @map("shift_period_start")
  shiftPeriodEnd      DateTime?                @map("shift_period_end")
  avatar              String?                  @db.VarChar(500)
  isActive            Boolean?                 @default(true) @map("is_active")
  isBlocked           Boolean?                 @default(false) @map("is_blocked")
  isFirstLogin        Boolean?                 @default(true) @map("is_first_login")
  mustChangePassword  Boolean?                 @default(true) @map("must_change_password")
  lastActivity        DateTime?                @map("last_activity")
  failedLoginAttempts Int?                     @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?                @map("locked_until")
  monthlyScore        Float?                   @map("monthly_score") @db.Float
  reliabilityIndex    Float?                   @map("reliability_index") @db.Float
  performanceBadge    users_performance_badge? @map("performance_badge")
  presenceStatus      users_presence_status?   @default(OFFLINE) @map("presence_status")
  createdAt           DateTime?                @default(now()) @map("created_at")
  updatedAt           DateTime?                @default(now()) @updatedAt @map("updated_at")
  activities          Activity[]
  auditLogs           AuditLog[]
  dayAssignments      DayAssignment[]
  documentShares      DocumentShare[]
  documentVersions    DocumentVersion[]
  documents           Document[]
  graphSchedules      GraphSchedule[]
  handovers           Handover[]
  individualRests     IndividualRest[]
  notifications       Notification[]
  overtimes           Overtime[]
  responsibilities    Responsibility[]
  sessions            Session[]
  taskComments        TaskComment[]
  tasks               Task[]
  ticketAttachments   TicketAttachment[]
  ticketComments      TicketComment[]
  assignedTickets     Ticket[]                 @relation("TicketAssignee")
  reportedTickets     Ticket[]                 @relation("TicketReporter")
  shift               Shift?                   @relation(fields: [shiftId], references: [id], onUpdate: NoAction, map: "fk_users_shift")

  @@index([role], map: "idx_users_role")
  @@index([shiftId], map: "idx_users_shift_id")
  @@map("users")
}

model Shift {
  id          String       @id @default(cuid())
  name        String       @unique(map: "uk_shifts_name")
  color       String
  colorCode   String       @map("color_code")
  description String?      @db.VarChar(500)
  createdAt   DateTime?    @default(now()) @map("created_at")
  updatedAt   DateTime?    @default(now()) @map("updated_at")
  handovers   Handover[]
  cycles      ShiftCycle[]
  members     User[]

  @@map("shifts")
}

model ShiftCycle {
  id              String           @id @default(cuid())
  shiftId         String           @map("shift_id")
  startDate       DateTime         @map("start_date")
  endDate         DateTime         @map("end_date")
  cycleNumber     Int              @map("cycle_number")
  isActive        Boolean?         @default(true) @map("is_active")
  createdAt       DateTime?        @default(now()) @map("created_at")
  individualRests IndividualRest[]
  shift           Shift            @relation(fields: [shiftId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_shift_cycles_shift")
  workDays        WorkDay[]

  @@index([shiftId, cycleNumber], map: "idx_shift_cycles_shift_number")
  @@index([shiftId, startDate], map: "idx_shift_cycles_shift_start")
  @@map("shift_cycles")
}

model WorkDay {
  id          String          @id @default(cuid())
  cycleId     String          @map("cycle_id")
  date        DateTime
  dayType     DayType         @map("day_type")
  startHour   Int             @map("start_hour")
  endHour     Int             @map("end_hour")
  dayNumber   Int             @map("day_number")
  createdAt   DateTime?       @default(now()) @map("created_at")
  assignments DayAssignment[]
  cycle       ShiftCycle      @relation(fields: [cycleId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_work_days_cycle")

  @@unique([cycleId, date], map: "uk_work_days_cycle_date")
  @@index([cycleId], map: "idx_work_days_cycle_id")
  @@index([date], map: "idx_work_days_date")
  @@map("work_days")
}

model DayAssignment {
  id             String              @id @default(cuid())
  workDayId      String              @map("work_day_id")
  userId         String              @map("user_id")
  responsibility ResponsibilityType?
  isResting      Boolean?            @default(false) @map("is_resting")
  createdAt      DateTime?           @default(now()) @map("created_at")
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_day_assignments_user")
  workDay        WorkDay             @relation(fields: [workDayId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_day_assignments_work_day")

  @@unique([workDayId, userId], map: "uk_day_assignments_workday_user")
  @@index([userId], map: "fk_day_assignments_user")
  @@map("day_assignments")
}

model IndividualRest {
  id        String     @id @default(cuid())
  cycleId   String     @map("cycle_id")
  userId    String     @map("user_id")
  restDay   Int        @map("rest_day")
  createdAt DateTime?  @default(now()) @map("created_at")
  cycle     ShiftCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_individual_rests_cycle")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_individual_rests_user")

  @@unique([cycleId, userId], map: "uk_individual_rests_cycle_user")
  @@index([userId], map: "fk_individual_rests_user")
  @@map("individual_rests")
}

model Activity {
  id          String       @id @default(cuid())
  userId      String       @map("user_id")
  type        ActivityType
  category    String
  description String       @db.Text
  metadata    String?      @db.Text
  createdAt   DateTime?    @default(now()) @map("created_at")
  updatedAt   DateTime?    @default(now()) @map("updated_at")
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_activities_user")

  @@index([category], map: "idx_activities_category")
  @@index([type], map: "idx_activities_type")
  @@index([userId, createdAt], map: "idx_activities_user_created")
  @@map("activities")
}

model Task {
  id                String              @id @default(cuid())
  userId            String              @map("user_id")
  title             String              @db.VarChar(500)
  description       String?             @db.Text
  status            tasks_status?       @default(PENDING)
  category          tasks_category?     @default(OTHER)
  priority          tasks_priority?     @default(MEDIUM)
  responsibility    ResponsibilityType?
  shiftName         String?             @map("shift_name") @db.VarChar(50)
  startTime         DateTime?           @map("start_time")
  estimatedEndTime  DateTime?           @map("estimated_end_time")
  estimatedDuration Int?                @map("estimated_duration")
  actualEndTime     DateTime?           @map("actual_end_time")
  actualDuration    Int?                @map("actual_duration")
  tags              String?             @db.Text
  isOverdue         Boolean?            @default(false) @map("is_overdue")
  isNotified        Boolean?            @default(false) @map("is_notified")
  completedAt       DateTime?           @map("completed_at")
  createdAt         DateTime?           @default(now()) @map("created_at")
  updatedAt         DateTime?           @default(now()) @updatedAt @map("updated_at")
  alerts            TaskAlert[]
  comments          TaskComment[]
  history           TaskHistory[]
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tasks_user")

  @@index([category], map: "idx_tasks_category")
  @@index([priority], map: "idx_tasks_priority")
  @@index([userId, createdAt], map: "idx_tasks_user_created")
  @@index([userId, status], map: "idx_tasks_user_status")
  @@map("tasks")
}

model GraphSchedule {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  date       DateTime
  time       String    @db.VarChar(20)
  sent       Boolean?  @default(false)
  recipients String?   @db.Text
  createdAt  DateTime? @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_graph_schedules_user")

  @@index([userId], map: "fk_graph_schedules_user")
  @@index([date], map: "idx_graph_schedules_date")
  @@map("graph_schedules")
}

model Handover {
  id           String    @id @default(cuid())
  authorId     String    @map("author_id")
  shiftId      String    @map("shift_id")
  date         DateTime
  content      String?   @db.Text
  incidents    String?   @db.Text
  escalations  String?   @db.Text
  pendingTasks String?   @map("pending_tasks") @db.Text
  createdAt    DateTime? @default(now()) @map("created_at")
  updatedAt    DateTime? @default(now()) @map("updated_at")
  author       User      @relation(fields: [authorId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_handovers_author")
  shift        Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_handovers_shift")

  @@index([authorId, date], map: "idx_handovers_author_date")
  @@index([shiftId, date], map: "idx_handovers_shift_date")
  @@map("handovers")
}

model Overtime {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  date       DateTime
  duration   Int       @default(120)
  shiftType  String    @map("shift_type") @db.VarChar(50)
  startTime  String    @map("start_time") @db.VarChar(20)
  endTime    String    @map("end_time") @db.VarChar(20)
  reason     String?   @default("Supervision NOC") @db.VarChar(500)
  approvedBy String?   @default("Daddy AZUMY") @map("approved_by")
  month      Int
  year       Int
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @default(now()) @map("updated_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_overtimes_user")

  @@unique([userId, date], map: "uk_overtimes_user_date")
  @@index([date], map: "idx_overtimes_date")
  @@index([userId, month, year], map: "idx_overtimes_user_month_year")
  @@map("overtimes")
}

model Responsibility {
  id             String             @id @default(cuid())
  userId         String             @map("user_id")
  responsibility ResponsibilityType
  startDate      DateTime           @map("start_date")
  endDate        DateTime?          @map("end_date")
  isActive       Boolean?           @default(true) @map("is_active")
  createdAt      DateTime?          @default(now()) @map("created_at")
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_responsibilities_user")

  @@index([userId, startDate], map: "idx_responsibilities_user_start")
  @@map("responsibilities")
}

model ExternalLink {
  id          String    @id @default(cuid())
  name        String    @db.VarChar(200)
  url         String    @db.Text
  category    String    @db.VarChar(100)
  icon        String?   @db.VarChar(100)
  description String?   @db.VarChar(500)
  order       Int?      @default(0)
  isActive    Boolean?  @default(true) @map("is_active")
  createdAt   DateTime? @default(now()) @map("created_at")
  updated_at  DateTime? @default(now())

  @@map("external_links")
}

model SystemSetting {
  id          String    @id @default(cuid())
  key         String    @unique(map: "uk_system_settings_key")
  value       String?   @db.Text
  description String?   @db.VarChar(500)
  created_at  DateTime? @default(now())
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at")

  @@map("system_settings")
}

