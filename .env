# ============================================
# NOC Activities - Environment Variables
# ============================================

# DATABASE - MySQL (WampServer)
# Pour WampServer par défaut: root sans mot de passe
DATABASE_URL="mysql://root:@localhost:3306/noc_activity"
# Si mot de passe MySQL:
# DATABASE_URL="mysql://root:votre_mot_de_passe@localhost:3306/noc_activity"

# JWT SECRET
JWT_SECRET="silicone-connect-secret-key-2026-secure"

# NEXTAUTH
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="silicone-connect-nextauth-secret-2026"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="NOC Activities - Silicone Connect"
